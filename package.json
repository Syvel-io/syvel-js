{
  "name": "@syvel/js",
  "version": "0.1.0",
  "description": "Disposable email detection SDK for JavaScript and TypeScript",
  "keywords": [
    "disposable email",
    "email validation",
    "email verification",
    "temporary email",
    "spam detection",
    "syvel"
  ],
  "homepage": "https://www.syvel.io/docs/integrations/javascript",
  "repository": {
    "type": "git",
    "url": "https://github.com/syvel-io/syvel-js.git"
  },
  "bugs": {
    "url": "https://github.com/syvel-io/syvel-js/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run src/__tests__/client.test.ts",
    "test:integration": "vitest run src/__tests__/integration.test.ts",
    "test:watch": "vitest",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint:check && npm run build && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
